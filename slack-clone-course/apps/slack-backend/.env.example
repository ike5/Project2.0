# Copy to .env for local dev:  cp .env.example .env
# Settings are read from these via django-environ (12-factor config).

DEBUG=true
SECRET_KEY=dev-only-change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres + Redis from 00-setup/compose.dev.yml
DATABASE_URL=postgres://slack:slack@localhost:5432/slack
REDIS_URL=redis://localhost:6379/0

# Email (MailHog from compose.dev.yml) — used from Module 07
EMAIL_HOST=localhost
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=no-reply@slackclone.local

# Object storage (MinIO from compose.dev.yml) — used from Module 11
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=slack-uploads

# Frontend origin for CORS / CSRF (Module 09)
FRONTEND_ORIGIN=http://localhost:3000
